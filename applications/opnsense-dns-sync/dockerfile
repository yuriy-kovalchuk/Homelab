# Stage 1: Build the Go application
FROM golang:1.25.4-alpine AS builder

# Install git (needed for Go modules)
RUN apk add --no-cache git

# Set the working directory in the container
WORKDIR /app

# Copy Go module files
COPY src/go.mod src/go.sum ./

# Download dependencies
RUN go mod download

# Copy the entire project
COPY src/ .

# Build the Go application from src/cmd/dns-sync
ARG TARGETOS=linux
ARG TARGETARCH=amd64
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build -trimpath -ldflags "-s -w" -o /dns-sync ./cmd/dns-sync

# Stage 2: Create the final image
FROM alpine:3.22.2

# Set author information
LABEL maintainer="Yuriy Kovalchuk <yuriy.kovalchuk@proton.me>"

# Set working directory
WORKDIR /app

# Create non-root user and install CA certificates for HTTPS
RUN addgroup -S app && adduser -S app -G app && apk add --no-cache ca-certificates

# Copy the Go binary from the builder stage
COPY --from=builder /dns-sync /app/dns-sync

# Drop privileges
USER app

# Set entrypoint
ENTRYPOINT ["./dns-sync"]

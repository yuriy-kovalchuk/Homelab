.env
.devbox
.venv
.playground

# -------------------------
# Helm & Helm Charts
# -------------------------

# Packaged charts anywhere
**/*.tgz

# Helm chart dependencies anywhere
**/charts/
**/Chart.lock

# Helm debug logs anywhere
**/helm-debug.log

# Helm plugin cache
**/.helm/cache/
**/.helm/repository/
**/.helm/tmp/
**/.helm/plugins/

# Helm local repo cache
**/helm-repo-cache/

# -------------------------
# ArgoCD
# -------------------------

# ArgoCD autogenerated manifests anywhere
**/*.argocd.yaml
**/argocd-apps/
**/argocd-config/

# -------------------------
# Kubernetes / general
# -------------------------

# kubectl / kustomize output
**/.kube/
**/.kustomize-cache/

# YAML temp files anywhere
**/*.yaml~
**/*.yml~

# -------------------------
# IDE / editor files
# -------------------------
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
**/*.bak
**/*.tmp

# -------------------------
# OS generated
# -------------------------
**/.DS_Store
**/Thumbs.db
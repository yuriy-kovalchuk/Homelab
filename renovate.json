// renovate.json (In GitHub Repository Root)
{
  "extends": [
    "config:base"
  ],
  "enabled": true,
  "prCreation": "off",
  "dependencyDashboard": true,

  "includePaths": [
    "kubernetes/apps/**"
  ],

  "packageRules": [
    {
      "matchManagers": ["helmv3", "helm-requirements"],
      "enabled": true
    }
  ]
}
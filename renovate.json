{
  "extends": [
    "config:base"
  ],
  "enabled": true,
  "prCreation": "off",
  "branchCreation": "off",
  "dependencyDashboard": true,
  "includePaths": [
    "kubernetes/apps/**"
  ],

  "packageRules": [
    {
      "matchManagers": ["helmv3", "helm-requirements"],
      "fileMatch": [
        "**/Chart.yaml",
        "**/requirements.yaml"
      ],
      "enabled": true
    }
  ]
}
{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.0/.schema/devbox.schema.json",
  "packages": [
    "ansible@2.18.1",
    "python3",
    "python3Packages.pip",
    "python3Packages.proxmoxer",
    "python3Packages.requests",
    "python3Packages.urllib3",
    "sshpass",
    "gum@0.16.0",
    "gettext@0.22.5",
    "kubectl@1.32.2",
    "kubernetes-helm@3.17.2",
    "kubeseal@0.29.0"
  ],
  "shell": {
    "init_hook": [
      "chmod +x devbox_scripts/*",
      "export $(cat .env | xargs)",
      "echo Letsgoski letsgo!"
    ],
    "scripts": {
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ],
      "prx_download_base_image":     "./devbox_scripts/download_cloud_init.sh",
      "prx_create_vm_template": "./devbox_scripts/create_vm_template.sh",
      "prx_create_vm":       "./devbox_scripts/create_vm_from_template.sh",
      "argo_new_app":       "./devbox_scripts/new_app.sh $@",
      "k_ss_create":       "./devbox_scripts/create_sealed_secret.sh $1 $2 $3 $4"
    }
  }
}
